---
/**
 * HeroSection — Landing page hero with gradient title, slogan, and gold divider.
 * Designed for the splash template on the zh/index.mdx page.
 *
 * @prop subtitle - English subtitle displayed above the main title
 * @prop title - Main title text (default: localized)
 * @prop slogan - Slogan text in gold
 */
import { t, getLocale } from '../../i18n/ui';

interface Props {
  brandTag?: string;
  subtitle?: string;
  title?: string;
  slogan?: string;
}

const locale = getLocale(Astro.currentLocale, Astro.url.pathname);

const {
  brandTag = t(locale, 'hero.brandTag'),
  subtitle = t(locale, 'hero.subtitle'),
  title = t(locale, 'hero.title'),
  slogan = t(locale, 'hero.slogan'),
} = Astro.props;

const searchPlaceholder = t(locale, 'hero.searchPlaceholder');
const searchLabel = t(locale, 'hero.searchLabel');
const ctaPrimary = t(locale, 'hero.ctaPrimary');
const ctaPathway = t(locale, 'hero.ctaPathway');
const prefix = `/${locale}`;
---

<section class="hero-section" aria-label="Hero">
  <div class="hero-section__inner">
    <span class="hero-section__brand-tag glass-panel">{brandTag}</span>
    <span class="hero-section__subtitle">{subtitle}</span>
    <h1 class="hero-section__title hero-text-glow">
      <span class="hero-gradient-text">{title}</span>
    </h1>
    <p class="hero-section__slogan">{slogan}</p>

    <button
      class="hero-search"
      aria-label={searchLabel}
      id="hero-search-trigger"
    >
      <svg class="hero-search__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8" />
        <path d="M21 21l-4.35-4.35" />
      </svg>
      <span class="hero-search__text">{searchPlaceholder}</span>
      <kbd class="hero-search__kbd" aria-hidden="true">Ctrl K</kbd>
    </button>

    <div class="hero-section__ctas">
      <a href={`${prefix}/tools/ai-assistant/`} class="btn-primary">
        {ctaPrimary}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
        </svg>
      </a>
      <a href={`${prefix}/pathway/`} class="btn-ghost">
        {ctaPathway}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </a>
    </div>

    <div class="hero-section__divider-wrapper" aria-hidden="true">
      <div class="hero-section__divider"></div>
    </div>
  </div>
</section>

<script>
  // Open Starlight's built-in Pagefind search dialog when hero search is clicked
  document.getElementById('hero-search-trigger')?.addEventListener('click', () => {
    const dialog = document.querySelector('site-search dialog') as HTMLDialogElement | null;
    if (dialog && !dialog.open) {
      dialog.showModal();
      // Focus the search input after dialog opens
      requestAnimationFrame(() => {
        const input = dialog.querySelector('input[type="search"], input[name="search"]') as HTMLInputElement | null;
        input?.focus();
      });
    }
  });
</script>

<style>
  .hero-section {
    position: relative;
    z-index: 10;
    padding-top: 2rem;
    padding-bottom: 4rem;
    padding-inline: var(--space-lg);
    overflow: hidden;
  }

  .hero-section__inner {
    max-width: 72rem;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xl);
  }

  /* English brand tag — Stitch "THE CELESTIAL PHARMACOPEIA" eyebrow */
  .hero-section__brand-tag {
    display: inline-block;
    padding: var(--space-xs) var(--space-md);
    color: var(--color-accent);
    font-family: var(--font-ui-accent);
    font-size: 0.75rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    margin-bottom: calc(-1 * var(--space-md));
  }

  /* Chinese/localized tagline under the brand tag */
  .hero-section__subtitle {
    display: inline-block;
    color: var(--color-text-secondary);
    font-family: var(--font-body);
    font-size: 0.875rem;
    letter-spacing: 0.12em;
  }

  .hero-section__title {
    font-family: var(--font-display);
    font-size: clamp(4rem, 10vw, 9rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin: 0;
  }

  .hero-section__slogan {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 3vw, 1.875rem);
    color: var(--color-accent);
    letter-spacing: 0.15em;
    margin: 0;
  }

  .hero-section__ctas {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
    justify-content: center;
  }

  /* Strip Starlight prose underline from hero CTA anchors */
  :global(.sl-markdown-content) .hero-section__ctas a,
  :global(.sl-markdown-content) .hero-section__ctas a:hover {
    text-decoration: none;
  }

  .hero-section__divider-wrapper {
    padding-top: var(--space-2xl);
    display: flex;
    justify-content: center;
  }

  .hero-section__divider {
    width: 1px;
    height: 6rem;
    background: linear-gradient(
      to bottom,
      var(--color-accent),
      transparent
    );
    opacity: 0.5;
  }

  /* --- Hero search trigger — glass panel search bar --- */
  .hero-search {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    width: 100%;
    max-width: 520px;
    padding: var(--space-md) var(--space-lg);
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--color-outline-20);
    color: var(--color-text-muted);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    cursor: pointer;
    transition:
      border-color var(--transition-normal),
      box-shadow var(--transition-normal),
      color var(--transition-fast);
    text-align: left;
  }

  .hero-search:hover {
    border-color: var(--color-primary);
    box-shadow: 0 0 20px var(--color-primary-alpha-15);
    color: var(--color-text-secondary);
  }

  .hero-search:focus-visible {
    border-color: var(--color-primary);
    box-shadow: 0 0 20px var(--color-primary-alpha-15);
    color: var(--color-text-secondary);
    outline: none;
  }

  .hero-search__icon {
    color: var(--color-text-muted);
    flex-shrink: 0;
    transition: color var(--transition-fast);
  }

  .hero-search:hover .hero-search__icon {
    color: var(--color-primary-light);
  }

  .hero-search__text {
    flex: 1;
  }

  .hero-search__kbd {
    display: none;
    font-family: var(--font-body);
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    border: 1px solid var(--color-outline-20);
    padding: 2px var(--space-sm);
    letter-spacing: 0.05em;
  }

  @media (min-width: 768px) {
    .hero-search__kbd {
      display: inline-block;
    }
  }

  @media (max-width: 480px) {
    .hero-search {
      padding: var(--space-sm) var(--space-md);
      font-size: 0.8125rem;
    }
  }
</style>
