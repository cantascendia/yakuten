---
/**
 * SiteFooter — Four-column footer with disclaimer, privacy, sources, dev docs.
 * Matches the Stitch design: mono font labels, muted text, gold headings.
 */
import { t, getLocale } from '../../i18n/ui';

interface FooterColumn {
  title: string;
  text: string;
}

const locale = getLocale(Astro.currentLocale, Astro.url.pathname);

const columns: FooterColumn[] = [
  {
    title: t(locale, 'footer.disclaimer.title'),
    text: t(locale, 'footer.disclaimer.text'),
  },
  {
    title: t(locale, 'footer.privacy.title'),
    text: t(locale, 'footer.privacy.text'),
  },
  {
    title: t(locale, 'footer.sources.title'),
    text: t(locale, 'footer.sources.text'),
  },
  {
    title: t(locale, 'footer.dev.title'),
    text: t(locale, 'footer.dev.text'),
  },
];
---

<footer class="site-footer" role="contentinfo">
  <div class="site-footer__inner">
    <div class="site-footer__grid">
      {columns.map((col) => (
        <div class="site-footer__column">
          <p class="site-footer__column-title">{col.title}</p>
          <p class="site-footer__column-text">{col.text}</p>
        </div>
      ))}
    </div>

    <div class="site-footer__bottom">
      <div class="site-footer__brand">{t(locale, 'footer.brand')}</div>
      <p class="site-footer__statement">
        {t(locale, 'footer.notice')}
      </p>
      <nav class="site-footer__links" aria-label={t(locale, 'footer.navLabel')}>
        <a href={`/${locale}/about/#隐私保障`}>{t(locale, 'footer.link.privacy')}</a>
        <a href={`/${locale}/about/#免责声明`}>{t(locale, 'footer.link.disclaimer')}</a>
        <a href="https://github.com/Loveil381/yakuten" rel="noopener noreferrer" target="_blank">{t(locale, 'footer.link.github')}</a>
        <a href="https://wj.qq.com/s2/26287720/da55/" rel="noopener noreferrer" target="_blank">{t(locale, 'footer.link.feedback')}</a>
      </nav>
      <p class="site-footer__copy">
        {t(locale, 'footer.copy')}
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    z-index: 10;
    width: 100%;
    padding-top: 5rem;
    padding-bottom: 3rem;
    background: var(--color-bg-primary);
    border-top: 1px solid rgba(86, 65, 71, 0.2);
  }

  .site-footer__inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 var(--space-lg);
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  /* --- Four-column grid --- */
  .site-footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    text-align: left;
  }

  @media (min-width: 640px) {
    .site-footer__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .site-footer__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .site-footer__column {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    border-left: 1px solid rgba(86, 65, 71, 0.15);
    padding-left: var(--space-md);
  }

  .site-footer__column-title {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin: 0;
  }

  .site-footer__column-text {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: rgba(203, 194, 221, 0.5);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    line-height: 1.8;
    margin: 0;
  }

  /* --- Bottom section --- */
  .site-footer__bottom {
    padding-top: 2rem;
    border-top: 1px solid rgba(86, 65, 71, 0.1);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
  }

  .site-footer__brand {
    color: var(--color-primary);
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 900;
    letter-spacing: 0.15em;
  }

  .site-footer__statement {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 900;
    color: var(--color-text-primary);
    margin: 0;
  }

  .site-footer__links {
    display: flex;
    gap: var(--space-xl);
    flex-wrap: wrap;
    justify-content: center;
  }

  .site-footer__links a {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: -0.02em;
    color: rgba(203, 194, 221, 0.3);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .site-footer__links a:hover {
    color: var(--color-accent);
  }

  .site-footer__copy {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: rgba(203, 194, 221, 0.3);
    letter-spacing: 0.4em;
    text-transform: uppercase;
    margin: 0;
  }
</style>
