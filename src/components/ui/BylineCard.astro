---
/**
 * BylineCard — author + reviewer + last-reviewed signature block.
 *
 * E-E-A-T purpose: make authorship, medical review, and freshness visible
 * to both humans and crawlers. Pair with JSON-LD (author / reviewedBy) in
 * JsonLd.astro or BlogPostJsonLd.astro for machine readability.
 *
 * Usage (MDX or Astro):
 *   <BylineCard
 *     author="编辑部"
 *     reviewer="XX 内分泌科 医师"
 *     reviewerCredential="MD, Endocrinology"
 *     lastReviewed="2026-04-15"
 *     nextReview="2026-10-15"
 *     evidenceLevel="A"
 *     refCount={9}
 *   />
 */
interface Props {
  author?: string;
  reviewer?: string;
  reviewerCredential?: string;
  lastReviewed: string;
  nextReview?: string;
  evidenceLevel?: 'A' | 'B' | 'C' | 'X';
  refCount?: number;
  locale?: 'zh' | 'en' | 'ja' | 'ko';
}

const {
  author = 'HRT药典编辑部',
  reviewer,
  reviewerCredential,
  lastReviewed,
  nextReview,
  evidenceLevel,
  refCount,
  locale = 'zh',
} = Astro.props;

const L = {
  zh: { author: '作者', reviewer: '医学复审', lastReviewed: '最后复查', nextReview: '下次复查', evidence: '证据等级', refs: '参考文献', refsSuffix: '篇' },
  en: { author: 'Author', reviewer: 'Medically reviewed', lastReviewed: 'Last reviewed', nextReview: 'Next review', evidence: 'Evidence', refs: 'References', refsSuffix: '' },
  ja: { author: '著者', reviewer: '医学監修', lastReviewed: '最終審査', nextReview: '次回審査', evidence: 'エビデンス', refs: '参考文献', refsSuffix: '件' },
  ko: { author: '저자', reviewer: '의학 검토', lastReviewed: '마지막 검토', nextReview: '다음 검토', evidence: '근거 등급', refs: '참고문헌', refsSuffix: '건' },
}[locale];
---

<aside class="byline-card" aria-label={L.reviewer}>
  <dl class="byline-card__grid">
    <div class="byline-card__row">
      <dt>{L.author}</dt>
      <dd>{author}</dd>
    </div>
    {reviewer && (
      <div class="byline-card__row">
        <dt>{L.reviewer}</dt>
        <dd>
          <span itemprop="reviewedBy">{reviewer}</span>
          {reviewerCredential && <span class="byline-card__cred"> · {reviewerCredential}</span>}
        </dd>
      </div>
    )}
    <div class="byline-card__row">
      <dt>{L.lastReviewed}</dt>
      <dd><time datetime={lastReviewed}>{lastReviewed}</time></dd>
    </div>
    {nextReview && (
      <div class="byline-card__row">
        <dt>{L.nextReview}</dt>
        <dd><time datetime={nextReview}>{nextReview}</time></dd>
      </div>
    )}
    {evidenceLevel && (
      <div class="byline-card__row">
        <dt>{L.evidence}</dt>
        <dd><span class={`byline-card__evidence byline-card__evidence--${evidenceLevel}`}>{evidenceLevel}</span></dd>
      </div>
    )}
    {typeof refCount === 'number' && refCount > 0 && (
      <div class="byline-card__row">
        <dt>{L.refs}</dt>
        <dd>{refCount}{L.refsSuffix}</dd>
      </div>
    )}
  </dl>
</aside>

<style>
  .byline-card {
    margin: var(--space-md) 0;
    padding: var(--space-sm) var(--space-md);
    background: rgba(26, 22, 37, 0.6);
    backdrop-filter: blur(12px);
    border: 1px solid var(--sl-color-gray-5, rgba(86, 65, 71, 0.25));
    border-radius: 8px;
    font-size: 0.8125rem;
    line-height: 1.5;
    clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
  }
  .byline-card__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--space-xs) var(--space-md);
    margin: 0;
  }
  .byline-card__row {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .byline-card__row dt {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-3, var(--color-text-muted, #888));
    margin: 0;
  }
  .byline-card__row dd {
    margin: 0;
    color: var(--sl-color-white, var(--color-text, #fff));
    font-family: var(--font-body);
  }
  .byline-card__cred {
    color: var(--sl-color-gray-3, var(--color-text-muted, #888));
    font-size: 0.75rem;
  }
  .byline-card__evidence {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5em;
    height: 1.5em;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 700;
    font-family: var(--font-mono);
    color: var(--color-text-on-dark, #fff);
  }
  .byline-card__evidence--A { background: var(--color-safe, #3fa66a); }
  .byline-card__evidence--B { background: var(--color-info, #4a8cc1); }
  .byline-card__evidence--C { background: var(--color-caution, #d4a853); }
  .byline-card__evidence--X { background: var(--color-danger, #c84b7c); }

  @media (prefers-reduced-motion: reduce) {
    .byline-card { backdrop-filter: none; }
  }
</style>
