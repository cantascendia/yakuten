---
/**
 * GuideCTA — 引导到任务型指南页的卡片式 CTA
 * 在药物/主题页内嵌，把读者引导到对应的 /guides/xxx/ 任务指南。
 *
 * @prop eyebrow    - 上方小标签（如「实操指南」「切换方案」）
 * @prop title      - 主标题（如「第一次打针？」）
 * @prop description- 一两句引导文案
 * @prop ctaText    - 按钮文字
 * @prop ctaHref    - 目标链接
 * @prop variant    - 'primary'（绯色，行动类）| 'accent'（金色，参考类），默认 primary
 */
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  ctaText: string;
  ctaHref: string;
  variant?: 'primary' | 'accent';
}

const {
  eyebrow,
  title,
  description,
  ctaText,
  ctaHref,
  variant = 'primary',
} = Astro.props;
---

<aside class:list={['guide-cta', `guide-cta--${variant}`]}>
  <div class="guide-cta__inner glass-panel clipped-card">
    <div class="guide-cta__body">
      <span class="guide-cta__eyebrow">{eyebrow}</span>
      <h3 class="guide-cta__title">{title}</h3>
      <p class="guide-cta__desc">{description}</p>
    </div>
    <a href={ctaHref} class={variant === 'accent' ? 'btn-ghost' : 'btn-primary'}>
      {ctaText}
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="5" y1="12" x2="19" y2="12" />
        <polyline points="12 5 19 12 12 19" />
      </svg>
    </a>
  </div>
</aside>

<style>
  .guide-cta {
    margin: var(--space-lg) 0;
  }

  .guide-cta__inner {
    position: relative;
    padding: var(--space-lg);
    padding-left: calc(var(--space-lg) + 3px);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    align-items: flex-start;
  }

  @media (min-width: 640px) {
    .guide-cta__inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-lg);
    }
    .guide-cta__body {
      flex: 1;
    }
  }

  /* Accent stripe — clip-path sweeps it along the diagonal, avoiding the
     border-seam problem that plain border-left would create. */
  .guide-cta__inner::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 3px;
    pointer-events: none;
  }
  .guide-cta--primary .guide-cta__inner::before {
    background: var(--color-primary);
  }
  .guide-cta--accent .guide-cta__inner::before {
    background: var(--color-accent);
  }

  .guide-cta__eyebrow {
    display: inline-block;
    font-family: var(--font-ui-accent);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-xs);
  }

  .guide-cta--primary .guide-cta__eyebrow {
    color: var(--color-primary-light);
  }

  .guide-cta__title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    margin: 0 0 var(--space-xs);
    color: var(--color-text-primary);
    line-height: 1.3;
  }

  .guide-cta__desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.6;
  }

  /* Strip Starlight prose underline from the CTA link when embedded in MDX */
  :global(.sl-markdown-content) .guide-cta a,
  :global(.sl-markdown-content) .guide-cta a:hover {
    text-decoration: none;
  }
</style>
