---
/**
 * JSON-LD Structured Data for SEO & AEO
 * Injects Organization + WebSite + MedicalWebPage schemas on every page.
 * Adds citation ScholarlyArticle schema when references are present.
 */
import refData from '../../data/references.json';

const route = Astro.locals.starlightRoute;
const pageUrl = Astro.url.href;
const pathname = Astro.url.pathname;
const locale = route?.lang ?? 'zh-CN';

// Extract page frontmatter
const entry = route?.entry;
const title = entry?.data?.title ?? 'HRT药典';
const description = entry?.data?.description ?? '';
const evidenceLevel = entry?.data?.evidenceLevel ?? 'X';
const lastReviewed = entry?.data?.lastReviewed
  ? new Date(entry.data.lastReviewed).toISOString().split('T')[0]
  : '2026-04-12';
const referenceIds: string[] = entry?.data?.references ?? [];

// ─── Breadcrumb label maps (per locale) ──────────────────────────────
// Intermediate path segments get localized names; the leaf uses entry.data.title.
type SegLabels = Record<string, string>;
const segmentLabelsMap: Record<string, SegLabels> = {
  'zh-CN': {
    medications: '药物详解',
    estrogens: '雌二醇',
    antiandrogens: '抗雄激素',
    progestogens: '孕激素',
    'five-alpha-reductase': '5α-还原酶抑制剂',
    tools: '工具',
    guides: '实操指南',
    blog: '专题文章',
  },
  en: {
    medications: 'Medications',
    estrogens: 'Estrogens',
    antiandrogens: 'Anti-Androgens',
    progestogens: 'Progestogens',
    'five-alpha-reductase': '5α-Reductase Inhibitors',
    tools: 'Tools',
    guides: 'Guides',
    blog: 'Blog',
  },
  ja: {
    medications: '薬物ガイド',
    estrogens: 'エストロゲン',
    antiandrogens: '抗アンドロゲン',
    progestogens: 'プロゲストーゲン',
    'five-alpha-reductase': '5α還元酵素阻害薬',
    tools: 'ツール',
    guides: 'ガイド',
    blog: 'ブログ',
  },
  ko: {
    medications: '약물',
    estrogens: '에스트로겐',
    antiandrogens: '항안드로겐',
    progestogens: '프로게스토겐',
    'five-alpha-reductase': '5α-환원효소 억제제',
    tools: '도구',
    guides: '가이드',
    blog: '블로그',
  },
};
const homeLabelsMap: Record<string, string> = {
  'zh-CN': '首页',
  en: 'Home',
  ja: 'ホーム',
  ko: '홈',
};
const segLabels: SegLabels = segmentLabelsMap[locale] ?? segmentLabelsMap['zh-CN'];
const homeLabel = homeLabelsMap[locale] ?? '首页';

// ─── Build breadcrumb items from pathname ──────────────────────────────
// e.g. "/zh/medications/estrogens/oral/" →
//   [Home, Medications, Estrogens, "口服雌二醇（补佳乐）"]
const pathSegments = pathname
  .replace(/^\/+|\/+$/g, '')
  .split('/')
  .filter(Boolean);
const localePrefix = pathSegments[0] ?? 'zh';
const contentSegments = pathSegments.slice(1);

type BreadcrumbItem = { name: string; url: string };
const breadcrumbs: BreadcrumbItem[] = [
  { name: homeLabel, url: `https://hrtyaku.com/${localePrefix}/` },
];
let accumulatedPath = `/${localePrefix}`;
contentSegments.forEach((seg, idx) => {
  accumulatedPath += `/${seg}`;
  const isLeaf = idx === contentSegments.length - 1;
  const name = isLeaf
    ? title
    : (segLabels[seg] ?? seg.charAt(0).toUpperCase() + seg.slice(1));
  breadcrumbs.push({
    name,
    url: `https://hrtyaku.com${accumulatedPath}/`,
  });
});

// Build reference citations for ScholarlyArticle schema
type RefEntry = { id: string; authors: string; year: number; title: string; journal: string; doi: string | null; url: string | null };
const refs = refData as RefEntry[];
const citedRefs = referenceIds
  .map((id: string) => refs.find((r: RefEntry) => r.id === id))
  .filter((r): r is RefEntry => r !== undefined)
  .slice(0, 5); // Limit to 5 for schema size

// Build the @graph array
const graph: Record<string, unknown>[] = [
  // 1. Organization (global)
  {
    "@type": "Organization",
    "@id": "https://hrtyaku.com/#organization",
    "name": "HRT药典",
    "alternateName": "HRT Yakuten",
    "url": "https://hrtyaku.com",
    "description": "Evidence-based harm reduction HRT safety information for transgender women.",
    "logo": {
      "@type": "ImageObject",
      "url": "https://hrtyaku.com/og-image.svg",
      "width": 1200,
      "height": 630
    },
    "sameAs": ["https://github.com/cantascendia/yakuten"]
  },
  // 2. WebSite (global)
  {
    "@type": "WebSite",
    "@id": "https://hrtyaku.com/#website",
    "url": "https://hrtyaku.com",
    "name": "HRT药典",
    "alternateName": "HRT Yakuten",
    "description": "循证 · 减害 · 引导就医 — Evidence-based HRT safety baseline for transgender women",
    "publisher": { "@id": "https://hrtyaku.com/#organization" },
    "inLanguage": ["zh-CN", "en", "ja"],
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://hrtyaku.com/zh/?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  },
  // 3. MedicalWebPage (per-page)
  {
    "@type": "MedicalWebPage",
    "url": pageUrl,
    "name": title,
    "description": description,
    "inLanguage": locale,
    "about": {
      "@type": "MedicalCondition",
      "name": "Gender Dysphoria",
      "code": {
        "@type": "MedicalCode",
        "code": "F64.0",
        "codingSystem": "ICD-10"
      }
    },
    "medicalAudience": {
      "@type": "MedicalAudience",
      "audienceType": "Patient"
    },
    "lastReviewed": lastReviewed,
    "reviewedBy": {
      "@type": "Organization",
      "name": "HRT药典 Editorial Team"
    },
    "isPartOf": { "@id": "https://hrtyaku.com/#website" }
  }
];

// 4. BreadcrumbList (per-page) — only if there's more than just the home
if (breadcrumbs.length > 1) {
  graph.push({
    "@type": "BreadcrumbList",
    "itemListElement": breadcrumbs.map((bc, idx) => ({
      "@type": "ListItem",
      "position": idx + 1,
      "name": bc.name,
      "item": bc.url,
    })),
  });
}

// Note: Drug schema intentionally omitted — Google requires offers/review/aggregateRating
// for Drug type, which doesn't apply to informational pages.
// MedicalWebPage above already provides medical semantic context.

// 5. Citation schemas (pages with references)
if (citedRefs.length > 0) {
  for (const ref of citedRefs) {
    graph.push({
      "@type": "ScholarlyArticle",
      "headline": ref.title,
      "author": ref.authors,
      "datePublished": String(ref.year),
      "isPartOf": { "name": ref.journal },
      ...(ref.doi ? { "sameAs": `https://doi.org/${ref.doi}` } : {}),
      ...(ref.url ? { "url": ref.url } : {})
    });
  }
}
---

<script is:inline type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@graph": graph
})} />
