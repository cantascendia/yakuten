---
/**
 * Head override — extends Starlight's default Head with:
 * - Vercel Analytics & Speed Insights
 * - hreflang alternate links (HTML head, complements sitemap hreflang)
 * - x-default hreflang for language negotiation
 */
import Default from '@astrojs/starlight/components/Head.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

const pathname = Astro.url.pathname;
const site = 'https://hrtyaku.com';

// Build hreflang alternates from current pathname
// Pattern: /{locale}/rest/of/path/ → extract locale, build alternates
const localeMap = [
  { code: 'zh-CN', prefix: '/zh/' },
  { code: 'en', prefix: '/en/' },
  { code: 'ja', prefix: '/ja/' },
  { code: 'ko', prefix: '/ko/' },
] as const;

// Extract the locale-independent path segment
let pagePath = '';
for (const { prefix } of localeMap) {
  if (pathname.startsWith(prefix)) {
    pagePath = pathname.slice(prefix.length);
    break;
  }
}

// Build alternate URLs
const alternates = localeMap.map(({ code, prefix }) => ({
  hreflang: code,
  href: `${site}${prefix}${pagePath}`,
}));

// x-default points to the default locale (zh)
const xDefault = `${site}/zh/${pagePath}`;

// Detect current locale for og:locale
const ogLocaleMap: Record<string, string> = { '/zh/': 'zh_CN', '/en/': 'en_US', '/ja/': 'ja_JP', '/ko/': 'ko_KR' };
const currentOgLocale = Object.entries(ogLocaleMap).find(([p]) => pathname.startsWith(p))?.[1] ?? 'zh_CN';
const alternateOgLocales = Object.values(ogLocaleMap).filter((l) => l !== currentOgLocale);
---

<Default {...Astro.props}><slot /></Default>
<link rel="manifest" href="/manifest.json" />
{alternates.map(({ hreflang, href }) => (
  <link rel="alternate" hreflang={hreflang} href={href} />
))}
<link rel="alternate" hreflang="x-default" href={xDefault} />
<meta property="og:locale" content={currentOgLocale} />
{alternateOgLocales.map((loc) => (
  <meta property="og:locale:alternate" content={loc} />
))}
<Analytics />
<SpeedInsights />
