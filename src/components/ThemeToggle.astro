---
/**
 * ThemeToggle — 左下角浮动按钮，跳转到新版设计预览
 *
 * 策略：物理隔离而非 CSS 换肤
 * - 点击按钮 → 跳转到 /sakura-preview.html（Claude Design 原版）
 * - 原网站一行代码都不动
 * - 新版页面有「返回」按钮跳回 /zh/
 *
 * 旧的 html.sakura class 机制保留，但这里不用了；
 * sakura-theme.css / sakura-skin.css 里的规则由于选择器不匹配，
 * 不会产生任何视觉影响。
 */
---

<style is:global>
  #sakura-toggle {
    position: fixed;
    bottom: 24px;
    left: 24px;
    z-index: 9999;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    font-family: var(--font-body, system-ui, sans-serif);
    font-size: 13px;
    font-weight: 500;
    color: var(--sl-color-text, #e6e0ee);
    background: rgba(26, 22, 37, 0.6);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(200, 175, 190, 0.25);
    border-radius: 999px;
    cursor: pointer;
    text-decoration: none;
    transition: transform 0.15s ease, background 0.15s ease, box-shadow 0.2s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  #sakura-toggle:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.2);
    background: rgba(229, 87, 139, 0.2);
  }

  #sakura-toggle:active {
    transform: translateY(0);
  }

  #sakura-toggle .sakura-toggle__icon {
    font-size: 14px;
    line-height: 1;
    transition: transform 0.3s ease;
  }

  #sakura-toggle:hover .sakura-toggle__icon {
    transform: rotate(20deg) scale(1.1);
  }

  @media (max-width: 640px) {
    #sakura-toggle {
      bottom: 16px;
      left: 16px;
      padding: 6px 12px;
      font-size: 12px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #sakura-toggle,
    #sakura-toggle .sakura-toggle__icon {
      transition: none;
    }
  }
</style>

<script is:inline>
  (function () {
    function mount() {
      if (document.getElementById("sakura-toggle")) return;
      var link = document.createElement("a");
      link.id = "sakura-toggle";
      link.href = "/sakura-preview.html";
      link.setAttribute("aria-label", "预览新版设计（Claude Design）");
      link.setAttribute("title", "预览新版设计（测试中）");
      link.innerHTML =
        '<span class="sakura-toggle__icon" aria-hidden="true">\uD83C\uDF38</span>' +
        '<span class="sakura-toggle__label">新版预览</span>';
      document.body.appendChild(link);
    }

    if (document.body) {
      mount();
    } else {
      document.addEventListener("DOMContentLoaded", mount);
    }
  })();
</script>
