---
/**
 * ThemeToggle — 右上角浮动按钮，切换原版深色 ↔ 樱粉手账风
 *
 * 实现：
 * - 通过 <html class="sakura"> 切换（不使用 data-theme 避免和 Starlight 内置主题冲突）
 * - 用脚本把 <button> 注入到 <body>（直接写在 <head> 里是非法 HTML）
 * - 状态持久化到 localStorage
 */
---

<style is:global>
  #sakura-toggle {
    position: fixed;
    bottom: 24px;
    left: 24px;
    z-index: 9999;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    font-family: var(--font-body, system-ui, sans-serif);
    font-size: 13px;
    font-weight: 500;
    color: var(--sl-color-text, #e6e0ee);
    background: rgba(26, 22, 37, 0.6);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(200, 175, 190, 0.25);
    border-radius: 999px;
    cursor: pointer;
    transition: transform 0.15s ease, background 0.15s ease, box-shadow 0.2s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  #sakura-toggle:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.2);
  }

  #sakura-toggle:active {
    transform: translateY(0);
  }

  #sakura-toggle .sakura-toggle__icon {
    font-size: 14px;
    line-height: 1;
    transition: transform 0.3s ease;
  }

  #sakura-toggle:hover .sakura-toggle__icon {
    transform: rotate(20deg) scale(1.1);
  }

  /* 激活态 */
  html.sakura #sakura-toggle {
    background: rgba(255, 255, 255, 0.85);
    border-color: #E5578B;
    color: #4A2838;
    box-shadow: 0 2px 10px rgba(229, 87, 139, 0.3);
  }

  html.sakura #sakura-toggle .sakura-toggle__label::after {
    content: " ✓";
    color: #E5578B;
  }

  @media (max-width: 640px) {
    #sakura-toggle {
      bottom: 16px;
      left: 16px;
      padding: 5px 10px;
      font-size: 12px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #sakura-toggle,
    #sakura-toggle .sakura-toggle__icon {
      transition: none;
    }
  }
</style>

<script is:inline>
  (function () {
    var KEY = "sakura-theme";
    var root = document.documentElement;

    // 初始化：从 localStorage 恢复
    try {
      if (localStorage.getItem(KEY) === "on") {
        root.classList.add("sakura");
      }
    } catch (e) {}

    function mount() {
      if (document.getElementById("sakura-toggle")) return;
      var btn = document.createElement("button");
      btn.id = "sakura-toggle";
      btn.type = "button";
      btn.setAttribute("aria-label", "切换樱粉手账主题");
      btn.setAttribute("title", "切换樱粉手账主题");
      btn.innerHTML =
        '<span class="sakura-toggle__icon" aria-hidden="true">\uD83C\uDF38</span>' +
        '<span class="sakura-toggle__label">樱粉</span>';
      btn.addEventListener("click", function () {
        var isOn = root.classList.contains("sakura");
        if (isOn) {
          root.classList.remove("sakura");
          try { localStorage.setItem(KEY, "off"); } catch (e) {}
        } else {
          root.classList.add("sakura");
          try { localStorage.setItem(KEY, "on"); } catch (e) {}
        }
      });
      document.body.appendChild(btn);
    }

    if (document.body) {
      mount();
    } else {
      document.addEventListener("DOMContentLoaded", mount);
    }
  })();
</script>
