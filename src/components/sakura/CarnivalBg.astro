---
/**
 * CarnivalBg — 手账纸底 + 散落樱花/奶黄/薄荷圆点
 * 对应设计包 Primitives.jsx 的 CarnivalBg，改为纯 CSS 固定底层
 */
---

<div class="carnival-bg" aria-hidden="true"></div>

<style>
  .carnival-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    background-color: #FFF5E0;
    /* 网点手账纸 */
    background-image:
      radial-gradient(circle at 2px 2px, rgba(74, 40, 56, 0.08) 1px, transparent 0);
    background-size: 22px 22px;
  }

  .carnival-bg::before,
  .carnival-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  /* 散落的樱花/奶黄/薄荷圆点 */
  .carnival-bg::before {
    background-image:
      radial-gradient(circle at 15% 20%, rgba(255, 168, 197, 0.35) 12px, transparent 13px),
      radial-gradient(circle at 72% 18%, rgba(255, 232, 156, 0.3) 10px, transparent 11px),
      radial-gradient(circle at 40% 65%, rgba(168, 230, 201, 0.28) 9px, transparent 10px),
      radial-gradient(circle at 85% 55%, rgba(212, 197, 245, 0.3) 11px, transparent 12px),
      radial-gradient(circle at 25% 85%, rgba(255, 212, 224, 0.35) 14px, transparent 15px),
      radial-gradient(circle at 60% 90%, rgba(168, 213, 245, 0.28) 8px, transparent 9px);
    background-size: 900px 900px;
    background-repeat: repeat;
  }
</style>
